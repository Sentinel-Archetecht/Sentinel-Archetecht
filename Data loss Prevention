        let engine = AmericanDLPEngine::new();
        
        let test_data = "My SSN is 123-45-6789 and email is test@example.com";
        let result = engine.scan_data(test_data, "default").unwrap();
        
        assert!(result.violation_detected);
        assert!(result.events.len() >= 2);
    }
