use anyhow::{Result, anyhow};
use serde::{Serialize, Deserialize};
use std::collections::HashMap;
use regex::Regex;

/// 🇺🇸 Sentinel Protocol - Data Loss Prevention
/// Prevents unauthorized data exfiltration and protects sensitive information
/// American innovation leading data protection

/// 🇺🇸 American DLP Engine
/// Leading the world in data loss prevention
pub struct AmericanDLPEngine {
    patterns: HashMap<String, DLPattern>,
    policies: HashMap<String, DLPPolicy>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct DLPattern {
    pub name: String,
    pub pattern: String,
    pub severity: Severity,
    pub category: DataCategory,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum Severity {
    Low,
    Medium,
    High,
    Critical,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum DataCategory {
    PII,
    Financial,
    Health,
    Confidential,
    Classified,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct DLPPolicy {
    pub name: String,
    pub action: DLPAction,
    pub notification_required: bool,
    pub encryption_required: bool,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum DLPAction {
    Block,
    Alert,
    Quarantine,
    Encrypt,
    Redact,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct DLPEvent {
    pub event_type: DLPEventType,
    pub pattern_detected: String,
    pub severity: Severity,
    pub data_hash: String,
    pub timestamp: chrono::DateTime<chrono::Utc>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum DLPEventType {
    PatternMatch,
    AnomalyDetected,
    PolicyViolation,
    DataExfiltrationAttempt,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct DLPResult {
    pub violation_detected: bool,
    pub events: Vec<DLPEvent>,
    pub recommended_action: DLPAction,
}

impl AmericanDLPEngine {
    /// 🇺🇸 Create new American DLP Engine
    pub fn new() -> Self {
        let mut patterns = HashMap::new();
        
        // SSN pattern
        patterns.insert("ssn".to_string(), DLPattern {
            name: "Social Security Number".to_string(),
            pattern: r"\b\d{3}-\d{2}-\d{4}\b".to_string(),
            severity: Severity::Critical,
            category: DataCategory::PII,
        });
        
        // Credit card pattern
        patterns.insert("credit_card".to_string(), DLPattern {
            name: "Credit Card Number".to_string(),
            pattern: r"\b\d{4}[ -]?\d{4}[ -]?\d{4}[ -]?\d{4}\b".to_string(),
            severity: Severity::High,
            category: DataCategory::Financial,
        });
        
        // Email pattern
        patterns.insert("email".to_string(), DLPattern {
            name: "Email Address".to_string(),
            pattern: r"\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b".to_string(),
            severity: Severity::Medium,
            category: DataCategory::Confidential,
        });
        
        let mut policies = HashMap::new();
        
        policies.insert("default".to_string(), DLPPolicy {
            name: "American Default DLP Policy".to_string(),
            action: DLPAction::Block,
            notification_required: true,
            encryption_required: true,
        });
        
        Self { patterns, policies }
    }
    
    /// 🇺🇸 Scan Data for Sensitive Information
    pub fn scan_data(&self, data: &str, policy_name: &str) -> Result<DLPResult> {
        let policy = self.policies.get(policy_name)
            .ok_or_else(|| anyhow!("Policy not found"))?;
        
        let mut events = Vec::new();
        let mut violation_detected = false;
        
        // Scan for all patterns
        for (pattern_name, pattern) in &self.patterns {
            if let Ok(regex) = Regex::new(&pattern.pattern) {
                if regex.is_match(data) {
                    let event = DLPEvent {
                        event_type: DLPEventType::PatternMatch,
                        pattern_detected: pattern.name.clone(),
                        severity: pattern.severity.clone(),
                        data_hash: self.hash_data(data),
                        timestamp: chrono::Utc::now(),
                    };
                    
                    events.push(event);
                    violation_detected = true;
                }
            }
        }
        
        Ok(DLPResult {
            violation_detected,
            events,
            recommended_action: policy.action.clone(),
        })
    }
    
    fn hash_data(&self, data: &str) -> String {
        // Simple hash for demonstration
        use std::collections::hash_map::DefaultHasher;
        use std::hash::{Hash, Hasher};
        
        let mut hasher = DefaultHasher::new();
        data.hash(&mut hasher);
        format!("{:x}", hasher.finish())
    }
}

