## 🔌 Bluetooth Low Energy (BLE) Implementation

### Core Technologies

#### 1. BLE Beacon Broadcasting
```javascript
// Beacon Data Structure
const beaconData = {
  protocol: 'sentinel',
  version: '1.0.0',
  userId: '0x123...',
  verificationLevel: 'PREMIUM',
  interests: ['governance', 'privacy', 'encryption'],
  governanceParticipation: true,
  timestamp: Date.now()
};

// Broadcast Configuration
const beaconConfig = {
  advertisingInterval: 100, // ms
  txPower: 'high', // -20 dBm
  connectable: false, // Non-connectable beacon
  data: encodeBeaconData(beaconData)
};
```

#### 2. BLE Scanning
```javascript
// Scan Configuration
const scanConfig = {
  scanMode: 'lowLatency', // Android
  allowDuplicates: false,
  scanningInterval: 500, // ms
  filter: {
    serviceUUIDs: ['sentinel-nudge-service']
  }
};

// Distance Calculation (RSSI-based)
function calculateDistance(rssi, txPower) {
  if (rssi === 0) return -1.0;
  
  const ratio = rssi * 1.0 / txPower;
  if (ratio < 1.0) {
    return Math.pow(ratio, 10);
  } else {
    return (0.89976) * Math.pow(ratio, 7.7095) + 0.111;
  }
}
```

### Platform-Specific Implementation

#### iOS Implementation
```swift
import CoreBluetooth

class SentinelBluetoothManager: NSObject, CBCentralManagerDelegate, CBPeripheralManagerDelegate {
  var centralManager: CBCentralManager!
  var peripheralManager: CBPeripheralManager!
  
  // Beacon UUID
  let sentinelServiceUUID = CBUUID(string: "SENTINEL-BEACON-0001")
  
  func startBeacon() {
    let beaconData = createBeaconData()
    let advertisementData = [
      CBAdvertisementDataServiceUUIDsKey: [sentinelServiceUUID],
      CBAdvertisementDataLocalNameKey: "Sentinel User",
      CBAdvertisementDataServiceDataKey: [
        sentinelServiceUUID: beaconData
      ]
    ]
    
    peripheralManager.startAdvertising(advertisementData)
  }
  
  func startScanning() {
    centralManager.scanForPeripherals(
      withServices: [sentinelServiceUUID],
      options: [CBCentralManagerScanOptionAllowDuplicatesKey: false]
    )
  }
  
  func centralManager(_ central: CBCentralManager, 
                      didDiscover peripheral: CBPeripheral, 
                      advertisementData: [String : Any], 
                      rssi RSSI: NSNumber) {
    let distance = calculateDistance(rssi: RSSI.intValue)
    let beaconData = decodeBeaconData(advertisementData)
    
    processDiscoveredUser(beaconData, distance: distance)
  }
}
```

#### Android Implementation
```kotlin
import android.bluetooth.BluetoothAdapter
import android.bluetooth.BluetoothManager
import android.bluetooth.le.*

class SentinelBluetoothManager(private val context: Context) {
  private val bluetoothManager = context.getSystemService(Context.BLUETOOTH_SERVICE) as BluetoothManager
  private val bluetoothAdapter = bluetoothManager.adapter
  private val bleScanner = bluetoothAdapter.bluetoothLeScanner
  
  private val SENTINEL_SERVICE_UUID = UUID.fromString("SENTINEL-BEACON-0001")
  
  fun startBeacon() {
    val beaconData = createBeaconData()
    val settings = AdvertiseSettings.Builder()
      .setAdvertiseMode(AdvertiseSettings.ADVERTISE_MODE_LOW_LATENCY)
      .setTxPowerLevel(AdvertiseSettings.ADVERTISE_TX_POWER_HIGH)
      .setConnectable(false)
      .build()
    
    val data = AdvertiseData.Builder()
      .setIncludeDeviceName(true)
      .addServiceUuid(ParcelUuid(SENTINEL_SERVICE_UUID))
      .addServiceData(ParcelUuid(SENTINEL_SERVICE_UUID), beaconData)
      .build()
    
    bluetoothAdapter.bluetoothLeAdvertiser.startAdvertising(settings, data, advertiseCallback)
  }
  
  fun startScanning() {
    val scanFilter = ScanFilter.Builder()
      .setServiceUuid(ParcelUuid(SENTINEL_SERVICE_UUID))
      .build()
    
    val scanSettings = ScanSettings.Builder()
      .setScanMode(ScanSettings.SCAN_MODE_LOW_LATENCY)
      .setReportDelay(0)
      .build()
    
    bleScanner.startScan(listOf(scanFilter), scanSettings, scanCallback)
  }
}
