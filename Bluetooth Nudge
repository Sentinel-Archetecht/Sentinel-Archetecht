#### 2. **Proposal Awareness**
```javascript
// Governance Nudge Logic
function generateGovernanceNudge(user, nearbyUsers, activeProposals) {
  const nearbyVoters = nearbyUsers.filter(
    u => u.governanceParticipation && u.activeProposalId
  );
  
  if (nearbyVoters.length >= 3) {
    const proposal = activeProposals.find(
      p => p.id === nearbyVoters[0].activeProposalId
    );
    
    return {
      type: 'GOVERNANCE',
      title: 'Vote Nearby!',
      body: `${nearbyVoters.length} people nearby are voting on "${proposal.title}"`,
      proposalId: proposal.id,
      deadline: proposal.votingEnds,
      action: 'QUICK_VOTE'
    };
  }
}
```

