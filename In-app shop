## 📱 Mobile App Integration

### iOS Implementation

```swift
// In-App Shop iOS Implementation
import UIKit

class InAppShopViewController: UIViewController {
    
    @IBOutlet var shopCollectionView: UICollectionView!
    @IBOutlet var categorySegmentedControl: UISegmentedControl!
    @IBOutlet var tokenBalanceLabel: UILabel!
    @IBOutlet var cartButton: UIBarButtonItem!
    
    var currentCategory: ShopCategory = .themes
    var shopItems: [ShopItem] = []
    var cart: [CartItem] = []
    
    override func viewDidLoad() {
        super.viewDidLoad()
        
        setupShop()
        loadShopItems()
        updateTokenBalance()
    }
    
    func setupShop() {
        // Setup collection view
        shopCollectionView.delegate = self
        shopCollectionView.dataSource = self
        
        // Setup categories
        let categories = ["Themes", "Badges", "Effects", "Animations", "Premium", "Limited"]
        categorySegmentedControl.removeAllSegments()
        for (index, category) in categories.enumerated() {
            categorySegmentedControl.insertSegment(withTitle: category, at: index, animated: false)
        }
        categorySegmentedControl.selectedSegmentIndex = 0
    }
    
    func loadShopItems() {
        ShopManager().getShopItems(category: currentCategory) { items in
            self.shopItems = items
            self.shopCollectionView.reloadData()
        }
    }
    
    func updateTokenBalance() {
        TokenManager().getTRVBalance { balance in
            self.tokenBalanceLabel.text = "\(balance) TRV"
        }
    }
    
    @IBAction func categoryChanged(_ sender: UISegmentedControl) {
        let categories: [ShopCategory] = [.themes, .badges, .effects, .animations, .premium, .limited]
        currentCategory = categories[sender.selectedSegmentIndex]
        loadShopItems()
    }
    
    func purchaseItem(_ item: ShopItem) {
        // Show purchase confirmation
        let alert = UIAlertController(
            title: "Purchase \(item.name)?",
            message: "Price: \(item.price) TRV\n\nAre you sure you want to purchase this item?",
            preferredStyle: .alert
        )
        
        alert.addAction(UIAlertAction(title: "Cancel", style: .cancel))
        alert.addAction(UIAlertAction(title: "Purchase", style: .default) { _ in
            self.executePurchase(item)
        })
        
        present(alert, animated: true)
    }
    
    func executePurchase(_ item: ShopItem) {
        ShopManager().purchaseItem(
            userId: currentUser.id,
            itemId: item.id,
            price: item.price
        ) { result in
            if result.success {
                // Show success
                self.showPurchaseSuccess(item)
                
                // Update balance
                self.updateTokenBalance()
                
                // Add to inventory
                self.addToInventory(item)
            } else {
                // Show error
                self.showError(result.error)
            }
        }
    }
    
    func showPurchaseSuccess(_ item: ShopItem) {
        let alert = UIAlertController(
            title: "Purchase Successful!",
            message: "You've purchased \(item.name)!",
            preferredStyle: .alert
        )
        
        alert.addAction(UIAlertAction(title: "OK", style: .default))
        present(alert, animated: true)
    }
}

extension InAppShopViewController: UICollectionViewDataSource, UICollectionViewDelegate {
    
    func collectionView(_ collectionView: UICollectionView, numberOfItemsInSection section: Int) -> Int {
        return shopItems.count
    }
    
    func collectionView(_ collectionView: UICollectionView, cellForItemAt indexPath: IndexPath) -> UICollectionViewCell {
        let cell = collectionView.dequeueReusableCell(
            withReuseIdentifier: "ShopItemCell",
            for: indexPath
        ) as! ShopItemCell
        
        let item = shopItems[indexPath.item]
        cell.configure(with: item)
        
        return cell
    }
    
    func collectionView(_ collectionView: UICollectionView, didSelectItemAt indexPath: IndexPath) {
        let item = shopItems[indexPath.item]
        showItemDetail(item)
    }
}
