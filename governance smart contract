pragma solidity ^0.8.20;

import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/governance/Governor.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorSettings.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorCountingSimple.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorVotes.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorVotesQuorumFraction.sol";
import "@openzeppelin/contracts/governance/extensions/GovernorTimelockControl.sol";
import "@openzeppelin/contracts/governance/TimelockController.sol";

/**
 * @title SentinelGovernance
 * @dev Implements "We The People" community governance with AI Mayor system
 * American innovation in decentralized governance
 */
contract SentinelGovernance is 
    Governor,
    GovernorSettings,
    GovernorCountingSimple,
    GovernorVotes,
    GovernorVotesQuorumFraction,
    GovernorTimelockControl,
    AccessControl
{
    // Roles
    bytes32 public constant AI_MAYOR_ROLE = keccak256("AI_MAYOR_ROLE");
    bytes32 public constant COMMUNITY_MEMBER_ROLE = keccak256("COMMUNITY_MEMBER_ROLE");
    bytes32 public constant PROPOSER_ROLE = keccak256("PROPOSER_ROLE");
    
    // Governance Parameters
    uint256 public constant VOTING_DELAY = 1 days;
    uint256 public constant VOTING_PERIOD = 7 days;
    uint256 public constant PROPOSAL_THRESHOLD = 1000e18; // 1000 tokens
    uint256 public constant QUORUM_PERCENTAGE = 4; // 4% of total supply
    
    // AI Mayor System
    address public aiMayorAddress;
    bool public aiMayorEnabled;
    uint256 public aiMayorTerm;
    uint256 public constant AI_MAYOR_TERM_LENGTH = 90 days;
    
    // Proposal Types
    enum ProposalType {
        PROTOCOL_UPGRADE,
        PARAMETER_CHANGE,
        FUNDING_ALLOCATION,
        AI_MAYOR_ELECTION,
        COMMUNITY_GUIDELINES
    }
    
    struct Proposal {
        ProposalType proposalType;
        string description;
        address proposer;
        uint256 createdAt;
        uint256 votingStarts;
        uint256 votingEnds;
        bool executed;
    }
    
    mapping(uint256 => Proposal) public proposals;
    uint256 public proposalCount;
    
    // Events
    event ProposalCreated(
        uint256 indexed proposalId,
        ProposalType proposalType,
        address indexed proposer,
        string description
    );
    
    event VoteCast(
        uint256 indexed proposalId,
        address indexed voter,
        uint8 support,
        uint256 weight
    );
    
    event ProposalExecuted(uint256 indexed proposalId, address indexed executor);
    
    event AIMayorElected(address indexed aiMayor, uint256 term);
    
    event AIMayorTermEnded(address indexed aiMayor);
    
    /**
     * @dev Constructor
     * @param _token The governance token address
     * @param _timelock The timelock controller address
     * @param _aiMayor Initial AI mayor address
     */
    constructor(
        IVotes _token,
        TimelockController _timelock,
        address _aiMayor
    )
        Governor("Sentinel Governance")
        GovernorSettings(
            VOTING_DELAY,
            VOTING_PERIOD,
            PROPOSAL_THRESHOLD
        )
        GovernorVotes(_token)
        GovernorVotesQuorumFraction(QUORUM_PERCENTAGE)
        GovernorTimelockControl(_timelock)
    {
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _grantRole(AI_MAYOR_ROLE, _aiMayor);
        _grantRole(COMMUNITY_MEMBER_ROLE, msg.sender);
        _grantRole(PROPOSER_ROLE, msg.sender);
        
        aiMayorAddress = _aiMayor;
        aiMayorEnabled = true;
        aiMayorTerm = block.timestamp + AI_MAYOR_TERM_LENGTH;
        
        emit AIMayorElected(_aiMayor, aiMayorTerm);
    }
    
    /**
     * @dev Create a new proposal
     * @param targets Contract addresses to call
     * @param values ETH values to send
     * @param calldatas Function call data
     * @param description Proposal description
     * @param proposalType Type of proposal
     * @return proposalId The proposal ID
     */
    function propose(
        address[] memory targets,
        uint256[] memory values,
        bytes[] memory calldatas,
        string memory description,
        ProposalType proposalType
    ) public override returns (uint256) {
        require(
            hasRole(PROPOSER_ROLE, msg.sender) ||
            getVotes(msg.sender, block.timestamp - 1) >= PROPOSAL_THRESHOLD,
            "Not authorized to propose"
        );
        
        uint256 proposalId = super.propose(
            targets,
            values,
            calldatas,
            description
        );
        
        proposals[proposalId] = Proposal({
            proposalType: proposalType,
            description: description,
            proposer: msg.sender,
            createdAt: block.timestamp,
            votingStarts: block.timestamp + VOTING_DELAY,
            votingEnds: block.timestamp + VOTING_DELAY + VOTING_PERIOD,
            executed: false
        });
        
        proposalCount++;
        
        emit ProposalCreated(
            proposalId,
            proposalType,
            msg.sender,
            description
        );
        
        return proposalId;
    }
    
    /**
     * @dev Cast vote on proposal
     * @param proposalId The proposal ID
     * @param support Vote (0=Against, 1=For, 2=Abstain)
     * @param reason Vote reason
     * @return balance The voting power used
     */
    function castVoteWithReason(
        uint256 proposalId,
        uint8 support,
        string calldata reason
    ) public override returns (uint256) {
        require(
            hasRole(COMMUNITY_MEMBER_ROLE, msg.sender),
            "Not a community member"
        );
        
        uint256 balance = super.castVoteWithReason(
            proposalId,
            support,
            reason
        );
        
        emit VoteCast(proposalId, msg.sender, support, balance);
        
        return balance;
    }
    
    /**
     * @dev Execute proposal after voting ends
     * @param targets Contract addresses to call
     * @param values ETH values to send
     * @param calldatas Function call data
     * @param descriptionHash Hashed description
     */
    function execute(
        address[] memory targets,
        uint256[] memory values,
        bytes[] memory calldatas,
        bytes32 descriptionHash
    ) public payable override returns (uint256) {
        uint256 proposalId = super.execute(
            targets,
            values,
            calldatas,
            descriptionHash
        );
        
        proposals[proposalId].executed = true;
        
        emit ProposalExecuted(proposalId, msg.sender);
        
        return proposalId;
    }
    
    /**
     * @dev Elect new AI Mayor
     * @param _newAIMayor New AI mayor address
     */
    function electAIMayor(address _newAIMayor) public onlyRole(AI_MAYOR_ROLE) {
        require(aiMayorEnabled, "AI Mayor system disabled");
        
        // End current AI Mayor term
        emit AIMayorTermEnded(aiMayorAddress);
        
        // Set new AI Mayor
        aiMayorAddress = _newAIMayor;
        aiMayorTerm = block.timestamp + AI_MAYOR_TERM_LENGTH;
        
        _grantRole(AI_MAYOR_ROLE, _newAIMayor);
        
        emit AIMayorElected(_newAIMayor, aiMayorTerm);
    }
    
    /**
     * @dev Check if AI Mayor term has expired
     */
    function isAIMayorTermExpired() public view returns (bool) {
        return block.timestamp >= aiMayorTerm;
    }
    
    /**
     * @dev Enable/disable AI Mayor system
     * @param _enabled Whether to enable AI Mayor
     */
    function setAIMayorEnabled(bool _enabled) public onlyRole(DEFAULT_ADMIN_ROLE) {
        aiMayorEnabled = _enabled;
    }
    
    /**
     * @dev Add community member
     * @param _member Address to add as member
     */
    function addCommunityMember(address _member) public onlyRole(DEFAULT_ADMIN_ROLE) {
        _grantRole(COMMUNITY_MEMBER_ROLE, _member);
    }
    
    /**
     * @dev Remove community member
     * @param _member Address to remove
     */
    function removeCommunityMember(address _member) public onlyRole(DEFAULT_ADMIN_ROLE) {
        _revokeRole(COMMUNITY_MEMBER_ROLE, _member);
    }
    
    /**
     * @dev Get proposal details
     * @param proposalId The proposal ID
     */
    function getProposal(uint256 proposalId) 
        public 
        view 
        returns (
            ProposalType proposalType,
            string memory description,
            address proposer,
            uint256 createdAt,
            uint256 votingStarts,
            uint256 votingEnds,
            bool executed
        ) 
    {
        Proposal memory proposal = proposals[proposalId];
        return (
            proposal.proposalType,
            proposal.description,
            proposal.proposer,
            proposal.createdAt,
            proposal.votingStarts,
            proposal.votingEnds,
            proposal.executed
        );
    }
    
    // The following functions are overrides required by Solidity
    
    function votingDelay()
        public
        pure
        override(Governor, GovernorSettings)
        returns (uint256)
    {
        return VOTING_DELAY;
    }

    function votingPeriod()
        public
        pure
        override(Governor, GovernorSettings)
        returns (uint256)
    {
        return VOTING_PERIOD;
    }

    function quorum(uint256 blockNumber)
        public
        view
        override(Governor, GovernorVotesQuorumFraction)
        returns (uint256)
    {
        return super.quorum(blockNumber);
    }

    function proposalThreshold()
        public
        pure
        override(Governor, GovernorSettings)
        returns (uint256)
    {
        return PROPOSAL_THRESHOLD;
    }
}

