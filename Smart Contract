pragma solidity ^0.8.20;

import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/utils/cryptography/ECDSA.sol";
import "@openzeppelin/contracts/utils/cryptography/EIP712.sol";

/**
 * @title SentinelStorage
 * @dev Implements data sovereignty proofs and access control management
 * American innovation in decentralized data ownership
 */
contract SentinelStorage is AccessControl, EIP712 {
    // Roles
    bytes32 public constant DATA_OWNER_ROLE = keccak256("DATA_OWNER_ROLE");
    bytes32 public constant STORAGE_PROVIDER_ROLE = keccak256("STORAGE_PROVIDER_ROLE");
    bytes32 public constant AUDITOR_ROLE = keccak256("AUDITOR_ROLE");
    
    // Data Categories
    enum DataCategory {
        PERSONAL,
        FINANCIAL,
        HEALTH,
        COMMUNICATION,
        MEDIA,
        DOCUMENTS
    }
    
    // Access Permissions
    enum Permission {
        READ,
        WRITE,
        DELETE,
        EXPORT,
        SHARE
    }
    
    // Consent Status
    enum ConsentStatus {
        GRANTED,
        REVOKED,
        EXPIRED,
        PENDING
    }
    
    // Data Record Structure
    struct DataRecord {
        bytes32 recordId;
        address owner;
        DataCategory category;
        string ipfsHash;
        string encryptionKeyHash;
        uint256 dataSize;
        uint256 createdAt;
        uint256 lastAccessed;
        uint256 accessCount;
        bool isActive;
        bool isEncrypted;
    }
    
    // Data Ownership Proof Structure
    struct OwnershipProof {
        bytes32 recordId;
        address owner;
        uint256 timestamp;
        bytes32 proofHash;
        bytes signature;
        bool isValid;
    }
    
    // Access Control Structure
    struct AccessControlEntry {
        bytes32 recordId;
        address grantee;
        Permission permission;
        uint256 grantedAt;
        uint256 expiresAt;
        ConsentStatus consentStatus;
        bool isActive;
    }
    
    // Consent Record Structure
    struct ConsentRecord {
        bytes32 consentId;
        address dataOwner;
        address dataProcessor;
        bytes32 recordId;
        Permission permission;
        ConsentStatus status;
        uint256 grantedAt;
        uint256 expiresAt;
        string purpose;
    }
    
    // Data Minimization Structure
    struct MinimizationRecord {
        bytes32 recordId;
        uint256 originalSize;
        uint256 minimizedSize;
        uint256 reductionPercentage;
        uint256 timestamp;
        string[] fieldsRemoved;
    }
    
    // State Variables
    uint256 private recordCounter;
    uint256 private consentCounter;
    
    mapping(bytes32 => DataRecord) public dataRecords;
    mapping(bytes32 => OwnershipProof) public ownershipProofs;
    mapping(bytes32 => AccessControlEntry[]) public accessControls;
    mapping(bytes32 => ConsentRecord) public consentRecords;
    mapping(bytes32 => MinimizationRecord) public minimizationRecords;
    
    mapping(address => bytes32[]) public ownerRecords;
    mapping(address => bytes32[]) public accessibleRecords;
    
    // Events
    event DataRecordCreated(
        bytes32 indexed recordId,
        address indexed owner,
        DataCategory category,
        string ipfsHash
    );
    
    event OwnershipProofCreated(
        bytes32 indexed recordId,
        address indexed owner,
        bytes32 proofHash
    );
    
    event AccessGranted(
        bytes32 indexed recordId,
        address indexed grantee,
        Permission permission
    );
    
    event AccessRevoked(
        bytes32 indexed recordId,
        address indexed grantee
    );
    
    event ConsentGranted(
        bytes32 indexed consentId,
        address indexed dataOwner,
        address indexed dataProcessor
    );
    
    event ConsentRevoked(
        bytes32 indexed consentId,
        address indexed dataOwner
    );
    
    event DataMinimized(
        bytes32 indexed recordId,
        uint256 reductionPercentage
    );
    
    event DataDeleted(
        bytes32 indexed recordId,
        address indexed owner
    );
    
    /**
     * @dev Constructor
     */
    constructor() EIP712("SentinelStorage", "1") {
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _grantRole(STORAGE_PROVIDER_ROLE, msg.sender);
        _grantRole(AUDITOR_ROLE, msg.sender);
        
        recordCounter = 1;
        consentCounter = 1;
    }
    
    /**
     * @dev Create new data record
     * @param _category Data category
     * @param _ipfsHash IPFS content hash
     * @param _encryptionKeyHash Hash of encryption key
     * @param _dataSize Size of data in bytes
     * @param _isEncrypted Whether data is encrypted
     */
    function createDataRecord(
        DataCategory _category,
        string memory _ipfsHash,
        string memory _encryptionKeyHash,
        uint256 _dataSize,
        bool _isEncrypted
    ) public returns (bytes32) {
        bytes32 recordId = keccak256(
            abi.encodePacked(
                msg.sender,
                _ipfsHash,
                block.timestamp,
                recordCounter++
            )
        );
        
        dataRecords[recordId] = DataRecord({
            recordId: recordId,
            owner: msg.sender,
            category: _category,
            ipfsHash: _ipfsHash,
            encryptionKeyHash: _encryptionKeyHash,
            dataSize: _dataSize,
            createdAt: block.timestamp,
            lastAccessed: block.timestamp,
            accessCount: 0,
            isActive: true,
            isEncrypted: _isEncrypted
        });
        
        ownerRecords[msg.sender].push(recordId);
        
        // Create ownership proof
        _createOwnershipProof(recordId);
        
        emit DataRecordCreated(recordId, msg.sender, _category, _ipfsHash);
        
        return recordId;
    }
    
    /**
     * @dev Create ownership proof
     * @param _recordId Data record ID
     */
    function _createOwnershipProof(bytes32 _recordId) internal {
        DataRecord memory record = dataRecords[_recordId];
        
        bytes32 proofHash = keccak256(
            abi.encodePacked(
                _recordId,
                record.owner,
                block.timestamp,
                record.ipfsHash,
                record.encryptionKeyHash
            )
        );
        
        bytes memory signature = _signOwnershipProof(proofHash);
        
        ownershipProofs[_recordId] = OwnershipProof({
            recordId: _recordId,
            owner: record.owner,
            timestamp: block.timestamp,
            proofHash: proofHash,
            signature: signature,
            isValid: true
        });
        
        emit OwnershipProofCreated(_recordId, record.owner, proofHash);
    }
    
    /**
     * @dev Sign ownership proof
     * @param _proofHash Hash to sign
     */
    function _signOwnershipProof(bytes32 _proofHash) internal view returns (bytes memory) {
        // In production, this would use the contract's private key
        // For now, return a placeholder
        return abi.encodePacked(_proofHash, block.timestamp);
    }
    
    /**
     * @dev Grant access to data
     * @param _recordId Data record ID
     * @param _grantee Address to grant access to
     * @param _permission Permission type
     * @param _expiresAt Expiration timestamp (0 for never)
     */
    function grantAccess(
        bytes32 _recordId,
        address _grantee,
        Permission _permission,
        uint256 _expiresAt
    ) public {
        require(dataRecords[_recordId].owner == msg.sender, "Not the owner");
        require(dataRecords[_recordId].isActive, "Record not active");
        require(_grantee != address(0), "Invalid grantee");
        
        AccessControlEntry memory accessControl = AccessControlEntry({
            recordId: _recordId,
            grantee: _grantee,
            permission: _permission,
            grantedAt: block.timestamp,
            expiresAt: _expiresAt,
            consentStatus: ConsentStatus.GRANTED,
            isActive: true
        });
        
        accessControls[_recordId].push(accessControl);
        
        if (!hasAccess(_grantee, _recordId)) {
            accessibleRecords[_grantee].push(_recordId);
        }
        
        emit AccessGranted(_recordId, _grantee, _permission);
    }
    
    /**
     * @dev Revoke access to data
     * @param _recordId Data record ID
     * @param _grantee Address to revoke access from
     */
    function revokeAccess(
        bytes32 _recordId,
        address _grantee
    ) public {
        require(dataRecords[_recordId].owner == msg.sender, "Not the owner");
        
        AccessControlEntry[] storage entries = accessControls[_recordId];
        for (uint256 i = 0; i < entries.length; i++) {
            if (entries[i].grantee == _grantee && entries[i].isActive) {
                entries[i].isActive = false;
                entries[i].consentStatus = ConsentStatus.REVOKED;
                break;
            }
        }
        
        emit AccessRevoked(_recordId, _grantee);
    }
    
    /**
     * @dev Grant consent
     * @param _recordId Data record ID
     * @param _dataProcessor Address of data processor
     * @param _permission Permission type
     * @param _purpose Purpose of data processing
     * @param _expiresAt Expiration timestamp
     */
    function grantConsent(
        bytes32 _recordId,
        address _dataProcessor,
        Permission _permission,
        string memory _purpose,
        uint256 _expiresAt
    ) public {
        require(dataRecords[_recordId].owner == msg.sender, "Not the owner");
        
        bytes32 consentId = keccak256(
            abi.encodePacked(
                msg.sender,
                _dataProcessor,
                _recordId,
                block.timestamp,
                consentCounter++
            )
        );
        
        consentRecords[consentId] = ConsentRecord({
            consentId: consentId,
            dataOwner: msg.sender,
            dataProcessor: _dataProcessor,
            recordId: _recordId,
            permission: _permission,
            status: ConsentStatus.GRANTED,
            grantedAt: block.timestamp,
            expiresAt: _expiresAt,
            purpose: _purpose
        });
        
        // Automatically grant access
        grantAccess(_recordId, _dataProcessor, _permission, _expiresAt);
        
        emit ConsentGranted(consentId, msg.sender, _dataProcessor);
    }
    
    /**
     * @dev Revoke consent
     * @param _consentId Consent ID
     */
    function revokeConsent(bytes32 _consentId) public {
        ConsentRecord storage consent = consentRecords[_consentId];
        
        require(consent.dataOwner == msg.sender, "Not the owner");
        require(consent.status == ConsentStatus.GRANTED, "Consent not granted");
        
        consent.status = ConsentStatus.REVOKED;
        
        // Revoke associated access
        revokeAccess(consent.recordId, consent.dataProcessor);
        
        emit ConsentRevoked(_consentId, msg.sender);
    }
    
    /**
     * @dev Minimize data
     * @param _recordId Data record ID
     * @param _originalSize Original data size
     * @param _minimizedSize Minimized data size
     * @param _fieldsRemoved List of removed fields
     */
    function minimizeData(
        bytes32 _recordId,
        uint256 _originalSize,
        uint256 _minimizedSize,
        string[] memory _fieldsRemoved
    ) public {
        require(dataRecords[_recordId].owner == msg.sender, "Not the owner");
        
        uint256 reductionPercentage = (_originalSize - _minimizedSize) * 100 / _originalSize;
        
        minimizationRecords[_recordId] = MinimizationRecord({
            recordId: _recordId,
            originalSize: _originalSize,
            minimizedSize: _minimizedSize,
            reductionPercentage: reductionPercentage,
            timestamp: block.timestamp,
            fieldsRemoved: _fieldsRemoved
        });
        
        // Update data record size
        dataRecords[_recordId].dataSize = _minimizedSize;
        
        emit DataMinimized(_recordId, reductionPercentage);
    }
    
    /**
     * @dev Delete data record
     * @param _recordId Data record ID
     */
    function deleteData(bytes32 _recordId) public {
        require(dataRecords[_recordId].owner == msg.sender, "Not the owner");
        
        dataRecords[_recordId].isActive = false;
        ownershipProofs[_recordId].isValid = false;
        
        // Revoke all access
        AccessControlEntry[] storage entries = accessControls[_recordId];
        for (uint256 i = 0; i < entries.length; i++) {
            entries[i].isActive = false;
        }
        
        emit DataDeleted(_recordId, msg.sender);
    }
    
    /**
     * @dev Check if address has access
     * @param _address Address to check
     * @param _recordId Data record ID
     */
    function hasAccess(
        address _address,
        bytes32 _recordId
    ) public view returns (bool) {
        // Owner always has access
        if (dataRecords[_recordId].owner == _address) {
            return true;
        }
        
        // Check access controls
        AccessControlEntry[] memory entries = accessControls[_recordId];
        for (uint256 i = 0; i < entries.length; i++) {
            if (
                entries[i].grantee == _address &&
                entries[i].isActive &&
                (entries[i].expiresAt == 0 || block.timestamp < entries[i].expiresAt)
            ) {
                return true;
            }
        }
        
        return false;
    }
    
    /**
     * @dev Get data record details
     * @param _recordId Data record ID
     */
    function getDataRecord(bytes32 _recordId) 
        public 
        view 
        returns (
            bytes32 recordId,
            address owner,
            DataCategory category,
            string memory ipfsHash,
            uint256 dataSize,
            uint256 createdAt,
            bool isActive,
            bool isEncrypted
        ) 
    {
        DataRecord memory record = dataRecords[_recordId];
        return (
            record.recordId,
            record.owner,
            record.category,
            record.ipfsHash,
            record.dataSize,
            record.createdAt,
            record.isActive,
            record.isEncrypted
        );
    }
    
    /**
     * @dev Get owner's data records
     * @param _owner Record owner
     */
    function getOwnerRecords(address _owner) 
        public 
        view 
        returns (bytes32[] memory) 
    {
        return ownerRecords[_owner];
    }
    
    /**
     * @dev Get records accessible to address
     * @param _address Address
     */
    function getAccessibleRecords(address _address) 
        public 
        view 
        returns (bytes32[] memory) 
    {
        return accessibleRecords[_address];
    }
}

