// Consent Management - User consent tracking and management

use anyhow::{Result, anyhow};
use serde::{Serialize, Deserialize};
use std::collections::HashMap;
use std::time::{Duration, Instant};

/// 🇺🇸 Sentinel Protocol - Consent Management
/// Manages user consent for data processing and usage
/// American innovation leading consent management

/// 🇺🇸 American Consent Management Engine
/// Leading the world in user consent tracking
pub struct AmericanConsentEngine {
    consents: HashMap<String, ConsentRecord>,
    consent_policies: HashMap<String, ConsentPolicy>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ConsentRecord {
    pub consent_id: String,
    pub user_id: String,
    pub consent_type: ConsentType,
    pub granted: bool,
    pub granted_at: Instant,
    pub expires_at: Option<Instant>,
    pub purpose: String,
    pub data_categories: Vec<String>,
    pub withdrawal_requested: bool,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum ConsentType {
    DataProcessing,
    DataSharing,
    DataUsage,
    Analytics,
    Marketing,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ConsentPolicy {
    pub policy_id: String,
    pub name: String,
    pub description: String,
    pub required_consents: Vec<ConsentType>,
    pub retention_period: Duration,
    pub withdrawal_process: String,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ConsentRequest {
    pub request_id: String,
    pub user_id: String,
    pub consent_types: Vec<ConsentType>,
    pub purpose: String,
    pub data_categories: Vec<String>,
    pub created_at: Instant,
    pub status: ConsentStatus,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum ConsentStatus {
    Pending,
    Granted,
    Denied,
    Withdrawn,
    Expired,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ConsentAuditLog {
    pub log_id: String,
    pub consent_id: String,
    pub action: ConsentAction,
    pub performed_at: Instant,
    pub performed_by: String,
    pub details: String,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum ConsentAction {
    Granted,
    Denied,
    Withdrawn,
    Modified,
    Expired,
}

impl AmericanConsentEngine {
    /// 🇺🇸 Create new American Consent Engine
    pub fn new() -> Self {
        Self {
            consents: HashMap::new(),
            consent_policies: HashMap::new(),
        }
    }
    
    /// 🇺🇸 Request Consent
    pub fn request_consent(&mut self, user_id: String, consent_types: Vec<ConsentType>, purpose: String, data_categories: Vec<String>) -> Result<ConsentRequest> {
        let request_id = format!("CON-REQ-{}", Instant::now().timestamp());
        
        let request = ConsentRequest {
            request_id: request_id.clone(),
            user_id,
            consent_types,
            purpose,
            data_categories,
            created_at: Instant::now(),
            status: ConsentStatus::Pending,
        };
        
        Ok(request)
    }
    
    /// 🇺🇸 Grant Consent
    pub fn grant_consent(&mut self, request_id: String, expires_at: Option<Instant>) -> Result<ConsentRecord> {
        let consent_id = format!("CON-{}", Instant::now().timestamp());
        
        // In production, this would validate the request and create the consent record
        let consent = ConsentRecord {
            consent_id: consent_id.clone(),
            user_id: "user123".to_string(),
            consent_type: ConsentType::DataProcessing,
            granted: true,
            granted_at: Instant::now(),
            expires_at,
            purpose: "Data processing".to_string(),
            data_categories: vec!["personal".to_string()],
            withdrawal_requested: false,
        };
        
        self.consents.insert(consent_id.clone(), consent.clone());
        Ok(consent)
    }
    
    /// 🇺🇸 Withdraw Consent
    pub fn withdraw_consent(&mut self, consent_id: String) -> Result<bool> {
        if let Some(consent) = self.consents.get_mut(&consent_id) {
            consent.granted = false;
            consent.withdrawal_requested = true;
            return Ok(true);
        }
        
        Err(anyhow!("Consent not found"))
    }
    
    /// 🇺🇸 Check Consent Status
    pub fn check_consent(&self, user_id: String, consent_type: ConsentType) -> Result<bool> {
        for consent in self.consents.values() {
            if consent.user_id == user_id && consent.consent_type == consent_type {
                if let Some(expires_at) = consent.expires_at {
                    if Instant::now() < expires_at && consent.granted {
                        return Ok(true);
                    }
                } else if consent.granted {
                    return Ok(true);
                }
            }
        }
        
        Ok(false)
    }
}

