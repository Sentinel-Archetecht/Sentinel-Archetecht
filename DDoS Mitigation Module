Architectural Overview
This document contains the production-ready, highly optimized Python implementation for the Sentinel Protocol's decentralized infrastructure layer. It replaces basic global tracking counters with a localized, memory-safe sliding window log algorithm to protect edge nodes against volumetric and layer-7 exploitation without relying on external networks, third-party frameworks, or centralized APIs.
import time
from collections import defaultdict, deque
from typing import Dict, Final

class DDoSLogMitigator:
    """
    Advanced sliding-window rate limiter for DDoS mitigation.
    Tracks individual IP footprints across a strict chronological window.
    Zero external service or cloud dependencies.
    """
    def __init__(self, max_requests_per_sec: int = 100, ban_duration_seconds: int = 60) -> None:
        self.threshold: Final[int] = max_requests_per_sec
        self.ban_duration: Final[int] = ban_duration_seconds
        
        # Tracks dynamic sliding windows of timestamps per IP locally in RAM
        self.request_logs: Dict[str, deque] = defaultdict(deque)
        # Tracks active local blocklists with expiration timestamps
        self.banned_ips: Dict[str, float] = {}

    def is_banned(self, ip: str, current_time: float) -> bool:
        """Checks and updates the local ban status of an IP."""
        if ip in self.banned_ips:
            if current_time < self.banned_ips[ip]:
                return True
            del self.banned_ips[ip]  # Ban expired natively
        return False

    def handle_request(self, ip: str, port: int) -> bool:
        """
        Evaluates incoming packets using a high-precision sliding window.
        Returns True if the request is permitted, False if dropped.
        """
        now = time.time()

        # 1. Check existing local ban state
        if self.is_banned(ip, now):
            # Extend ban under continuous flood
            self.banned_ips[ip] = now + self.ban_duration
            return False

        # 2. Prune timestamps older than 1 second from the sliding window
        ip_log = self.request_logs[ip]
        while ip_log and now - ip_log[0] > 1.0:
            ip_log.popleft()

        # 3. Evaluate threshold capacity
        if len(ip_log) >= self.threshold:
            self.banned_ips[ip] = now + self.ban_duration
            if ip in self.request_logs:
                del self.request_logs[ip]
            return False

        # 4. Log valid request locally
        ip_log.append(now)
        return True



