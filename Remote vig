use std::f64::consts::PI;

#[derive(Debug, Clone)]
pub struct GeoCoordinate {
    pub latitude: f64,
    pub longitude: f64,
}

#[derive(Debug, Clone)]
pub struct RegistryRecord {
    pub id_hash: String,
    pub location: GeoCoordinate,
    pub verified_source: String,
}

#[derive(Debug, Clone)]
pub struct SecureTip {
    pub encrypted_payload: Vec<u8>,
    pub hardware_signature: Vec<u8>,
    pub timestamp: u64,
}

pub struct RemoteViewerCore {
    max_radius_meters: f64,
}

impl RemoteViewerCore {
    pub fn new(max_radius_meters: f64) -> Self {
        Self { max_radius_meters }
    }

    /// Computes the Haversine distance between two coordinates entirely offline in local memory.
    pub fn calculate_distance_meters(&self, p1: &GeoCoordinate, p2: &GeoCoordinate) -> f64 {
        let earth_radius_m = 6371_000.0;

        let d_lat = (p2.latitude - p1.latitude).to_radians();
        let d_lon = (p2.longitude - p1.longitude).to_radians();

        let lat1 = p1.latitude.to_radians();
        let lat2 = p2.latitude.to_radians();

        let a = (d_lat / 2.0).sin().powi(2)
            + lat1.cos() * lat2.cos() * (d_lon / 2.0).sin().powi(2);
        let c = 2.0 * a.sqrt().asin();

        earth_radius_m * c
    }

    /// Filters local registry records against current device position within the allowed geofence.
    pub fn evaluate_local_proximity(
        &self,
        current_position: &GeoCoordinate,
        records: &[RegistryRecord],
    ) -> Vec<RegistryRecord> {
        records
            .iter()
            .filter(|record| {
                let distance = self.calculate_distance_meters(current_position, &record.location);
                distance <= self.max_radius_meters
            })
            .cloned()
            .collect()
    }

    /// Validates hardware attestation and wraps tip payload for direct agency transmission.
    pub fn package_secure_tip(
        &self,
        payload: &[u8],
        signature: &[u8],
        timestamp: u64,
    ) -> Result<SecureTip, &'static str> {
        if signature.is_empty() {
            return Err("Hardware attestation signature missing.");
        }

        Ok(SecureTip {
            encrypted_payload: payload.to_vec(),
            hardware_signature: signature.to_vec(),
            timestamp,
        })
    }
}
